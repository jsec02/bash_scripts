#!/usr/bin/env bash

# ================================================================================
# =                                    MKSYM                                     =
# ================================================================================

create_symlinks() {
    while read -r source target sudo; do
        local cmd=()
        [[ "$sudo" == "true" ]] && cmd=(sudo)
        [[ -e $target ]] && "${cmd[@]}" rm --recursive --force "$target"
        "${cmd[@]}" mkdir --parents "$(dirname "$target")"
        "${cmd[@]}" ln --symbolic --force "$source" "$target"
    done < <(python "$HOME/inventory/parser.py" links "$HOSTNAME")
}

main() {
    create_symlinks
}

main
