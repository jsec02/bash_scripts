#!/usr/bin/env bash

# ================================================================================
# =                                     ADD                                      =
# ================================================================================

# Adds packages to a machines corresponding packages file for setup automation
# Checks if package exists in repositories
# Stages, commits, and pushes to GitHub

set -eou pipefail

NAME=${0##*/}

MACHINE=""

PACKAGE_MANAGER=""

PACKAGES=()
VALID_PACKAGES=()
INVALID_PACKAGES=()

require_wsl() {
    if [[ "$HOSTNAME" != "wsl" ]]; then
        echo "This script should only be run on wsl" >&2
        exit 1
    fi
}

usage() {
    echo "Usage: $NAME <package>... <machine> [-h|--help]"
    echo "  machines: wsl pi kali"
}

parse_args() {
    if (($# == 0)); then
        usage >&2
        exit 1
    fi

    while (($# > 0)); do
        case "$1" in
            wsl | pi | kali)
                MACHINE="$1"
                ;;
            yay | apt | pip)
                PACKAGE_MANAGER="$1"
                ;;
            -h | --help)
                usage
                exit
                ;;
            *)
                PACKAGES+=("$1")
                ;;
        esac
        shift
    done

    if [[ -z "$MACHINE" ]]; then
        echo "No machine was provided" >&2
        exit 1
    fi

    if [[ -z "$PACKAGE_MANAGER" ]]; then
        echo "No package manager was provided" >&2
        exit 1
    fi

    if ((${#PACKAGES[@]} == 0)); then
        echo "No packages were provided" >&2
        exit 1
    fi
}

check_connection() {
    [[ $MACHINE == "wsl" ]] && return

    if ! ssh "$MACHINE" exit &>/dev/null; then
        echo "Could not connect to $MACHINE" >&2
        exit 1
    fi
}

validate_package_manager() {
    local path

    path=$(packages_path)

    if [[ ! -f "$path" ]]; then
        echo "No $PACKAGE_MANAGER.txt file found for $MACHINE" >&2
        exit 1
    fi
}

verify_packages() {
    local query=()
    local package

    case $PACKAGE_MANAGER in
        yay)
            query=(yay -Si)
            ;;
        apt)
            query=(apt show)
            ;;
        pip)
            query=(pip show)
            ;;
    esac

    if [[ "$MACHINE" == "wsl" ]]; then
        ssh=()
    else
        ssh=(ssh "$MACHINE")
    fi

    for package in "${PACKAGES[@]}"; do
        if "${ssh[@]}" "${query[@]}" "$package" &>/dev/null; then
            VALID_PACKAGES+=("$package")
        else
            INVALID_PACKAGES+=("$package")
        fi
    done
}

packages_path() {
    echo "$HOME/packages/$MACHINE/$PACKAGE_MANAGER.txt"
}

add_packages() {
    local path
    local package

    path=$(packages_path)

    for package in "${VALID_PACKAGES[@]}"; do
        echo "$package" >>"$path"
    done

    sort --output="$path" "$path"
}

sync_packages() {
    local path

    path=$(packages_path)

    if (cd "$HOME/packages" \
        && git add "$path" \
        && git commit --message "chore: add ${1:2}" \
        && git push) &>/dev/null; then
        echo "Synced $MACHINE"
    else
        echo "Sync failed for $MACHINE" >&2
    fi
}

main() {
    require_wsl

    local path
    local joined_valid
    local joined_invalid

    parse_args "$@"

    path=$(packages_path)

    check_connection

    validate_package_manager

    verify_packages

    joined_valid=$(printf ', %s' "${VALID_PACKAGES[@]}")
    joined_invalid=$(printf ', %s' "${INVALID_PACKAGES[@]}")

    if ((${#VALID_PACKAGES[@]} == 0)); then
        echo "Invalid packages for $path: ${joined_invalid:2}" >&2
        exit 1
    fi

    add_packages

    sync_packages "$joined_valid"

    echo "Added packages to $path: ${joined_valid:2}"

    if ((${#INVALID_PACKAGES[@]} > 0)); then
        echo "Invalid packages for $path: ${joined_invalid:2}" >&2
    fi

}

main "$@"
