#!/usr/bin/env bash

# ================================================================================
# =                                     ADD                                      =
# ================================================================================

# Adds packages to a machines corresponding packages file for setup automation
# Checks if package exists in repositories
# Stages, commits, and pushes to GitHub

set -eou pipefail

NAME=${0##*/}

PACKAGES=()
TARGETS=()

require_wsl() {
    if [[ "$HOSTNAME" != "wsl" ]]; then
        echo "This script should only be run on wsl" >&2
        exit 1
    fi
}

usage() {
    echo "Usage: $NAME <package>... <target>... [-h|--help]"
    echo "  targets: wsl pi kali"
}

parse_args() {
    if (($# == 0)); then
        usage >&2
        exit 1
    fi

    while (($# > 0)); do
        case "$1" in
            wsl | pi | kali)
                TARGETS+=("$1")
                ;;
            -h | --help)
                usage
                exit
                ;;
            *)
                PACKAGES+=("$1")
                ;;
        esac
        shift
    done

    if ((${#TARGETS[@]} == 0)); then
        echo "No targets were provided" >&2
        exit 1
    fi

    if ((${#PACKAGES[@]} == 0)); then
        echo "No packages were provided" >&2
        exit 1
    fi
}

check_connection() {
    [[ $MACHINE == "wsl" ]] && return

    if ! ssh "$MACHINE" exit &>/dev/null; then
        echo "Could not connect to $MACHINE" >&2
        exit 1
    fi
}

verify_packages() {
    local query=()
    local package

    if [[ "$MACHINE" == "wsl" ]]; then
        if command -v yay &>/dev/null; then
            query=(yay -Si)
        else
            query=(pacman -Si)
        fi
    else
        query=(ssh "$MACHINE" apt show)
    fi

    for package in "${PACKAGES[@]}"; do
        if "${query[@]}" "$package" &>/dev/null; then
            VALID_PACKAGES+=("$package")
        else
            INVALID_PACKAGES+=("$package")
        fi
    done
}

packages_path() {
    local name

    if [[ "$MACHINE" == "wsl" ]]; then
        name="yay"
    else
        name="apt"
    fi

    echo "$HOME/bash/setup/packages/$MACHINE/$name.txt"
}

add_packages() {
    local path
    local package

    path=$(packages_path)

    for package in "${VALID_PACKAGES[@]}"; do
        echo "$package" >>"$path"
    done

    sort --output="$path" "$path"
}

sync_packages() {
    local path

    path=$(packages_path)

    if (cd "$HOME/bash/setup" \
        && git add "$path" \
        && git commit --message "chore: add ${1:2}" \
        && git push) &>/dev/null; then
        echo "Synced $MACHINE"
    else
        echo "Sync failed for $MACHINE" >&2
    fi
}

main() {
    require_wsl

    local joined_valid
    local joined_invalid

    parse_args "$@"

    for target in "${TARGETS[@]}"; do
        MACHINE="$target"

        VALID_PACKAGES=()
        INVALID_PACKAGES=()

        check_connection

        verify_packages

        joined_valid=$(printf ', %s' "${VALID_PACKAGES[@]}")
        joined_invalid=$(printf ', %s' "${INVALID_PACKAGES[@]}")

        if ((${#VALID_PACKAGES[@]} == 0)); then
            echo "Invalid packages for $MACHINE: ${joined_invalid:2}" >&2
            continue
        fi

        add_packages

        sync_packages "$joined_valid"

        echo "Added packages to $MACHINE: ${joined_valid:2}"

        if ((${#INVALID_PACKAGES[@]} > 0)); then
            echo "Invalid packages for $MACHINE: ${joined_invalid:2}" >&2
        fi
    done

}

main "$@"
