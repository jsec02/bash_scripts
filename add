#!/usr/bin/env bash

# ================================================================================
# =                                     ADD                                      =
# ================================================================================

# Adds packages to inventory.yaml file for setup automation
# Checks if package exists in repositories
# Stages, commits, and pushes to GitHub

set -eou pipefail

NAME=${0##*/}

MACHINE=""

PACKAGE_MANAGER=""

PACKAGES=()
VALID_PACKAGES=()
INVALID_PACKAGES=()

usage() {
    echo "Usage: $NAME <package>... <machine> [-h|--help]"
    echo "  machines: wsl pi kali"
}

check_for_yq() {
    if ! command -v yq &>/dev/null; then
        echo "yq not found" >&2
        exit 1
    fi
}

require_wsl() {
    if [[ "$HOSTNAME" != "wsl" ]]; then
        echo "This script should only be run on wsl" >&2
        exit 1
    fi
}

parse_args() {
    if (($# == 0)); then
        usage >&2
        exit 1
    fi

    while (($# > 0)); do
        case "$1" in
            wsl | pi | kali)
                MACHINE="$1"
                ;;
            yay | apt | pip2 | pip3)
                PACKAGE_MANAGER="$1"
                ;;
            -h | --help)
                usage
                exit
                ;;
            *)
                PACKAGES+=("$1")
                ;;
        esac
        shift
    done

    if [[ -z "$MACHINE" ]]; then
        echo "No machine was provided" >&2
        exit 1
    fi

    if [[ -z "$PACKAGE_MANAGER" ]]; then
        echo "No package manager was provided" >&2
        exit 1
    fi

    if ((${#PACKAGES[@]} == 0)); then
        echo "No packages were provided" >&2
        exit 1
    fi
}

check_connection() {
    [[ $MACHINE == "wsl" ]] && return

    if ! ssh "$MACHINE" exit &>/dev/null; then
        echo "Could not connect to $MACHINE" >&2
        exit 1
    fi
}

validate_package_manager() {
    local valid
    valid=$(python3 "$HOME/inventory/parser.py" package_managers "$MACHINE")

    if ! echo "${valid}" | grep --quiet --word-regexp "${PACKAGE_MANAGER}"; then
        echo "Invalid package manager for $MACHINE" >&2
        exit 1
    fi
}

verify_packages() {
    local query=()
    local ssh=()
    local package

    case $PACKAGE_MANAGER in
        yay)
            query=(yay -Si)
            ;;
        apt)
            query=(apt show)
            ;;
        pip2)
            query=(pip2 show)
            ;;
        pip3)
            query=(pip3 show)
            ;;
    esac

    if ! [[ "$MACHINE" == "wsl" ]]; then
        ssh=(ssh "$MACHINE")
    fi

    for package in "${PACKAGES[@]}"; do
        if "${ssh[@]}" "${query[@]}" "$package" &>/dev/null; then
            VALID_PACKAGES+=("$package")
        else
            INVALID_PACKAGES+=("$package")
        fi
    done
}

add_packages() {
    local package

    for package in "${VALID_PACKAGES[@]}"; do
        yq --in-place --yaml-output \
            ".machines.${MACHINE}.package_managers.${PACKAGE_MANAGER} += [\"${package}\"]" \
            "$HOME/inventory/inventory.yaml"
    done
}

sync_inventory() {
    if (cd "$HOME/inventory" \
        && git add "inventory.yaml" \
        && git commit --message "chore: add ${1:2} to $MACHINE $PACKAGE_MANAGER" \
        && git push) &>/dev/null; then
        echo "Synced $MACHINE"
    else
        echo "Sync failed for $MACHINE" >&2
    fi
}

main() {
    require_wsl

    check_for_yq

    local joined_valid
    local joined_invalid

    parse_args "$@"

    check_connection

    validate_package_manager

    verify_packages

    joined_valid=$(printf ', %s' "${VALID_PACKAGES[@]}")
    joined_invalid=$(printf ', %s' "${INVALID_PACKAGES[@]}")

    if ((${#VALID_PACKAGES[@]} == 0)); then
        echo "Invalid packages for $MACHINE $PACKAGE_MANAGER: ${joined_invalid:2}" >&2
        exit 1
    fi

    add_packages

    echo "Added packages to $MACHINE $PACKAGE_MANAGER: ${joined_valid:2}"

    sync_inventory "$joined_valid"

    if ((${#INVALID_PACKAGES[@]} > 0)); then
        echo "Invalid packages for $MACHINE $PACKAGE_MANAGER: ${joined_invalid:2}" >&2
    fi

}

main "$@"
