#!/usr/bin/env bash

# ================================================================================
# =                                     COPY                                     =
# ================================================================================

NAME=${0##*/}

SOURCES=()
TARGETS=()

declare -A SOURCES_MAPPING

SOURCES_MAPPING=(
    [zshrc]="$HOME/.zshrc"
    [zshenv]="$HOME/.zshenv"
    [zshenvlocal]="$HOME/.zshenv.local"
    [zprofile]="$HOME/.zprofile"
    [ssh]="$HOME/.ssh/config"
    [nvim]="$HOME/.config/nvim/"
    [yazi]="$HOME/.config/yazi/"
    [fzf]="$HOME/.config/fzf/"
    [zellij]="$HOME/.config/zellij/"
    [atuin]="$HOME/dotfiles/atuin/"
)

require_wsl() {
    if [[ "$HOSTNAME" != "wsl" ]]; then
        echo "This script should only be run on wsl" >&2
        exit 1
    fi
}

usage() {
    echo "Usage: $NAME <source>... <target>... [-h|--help]"
    echo "  sources: zshrc zshenv zshenvlocal zprofile ssh nvim yazi fzf zellij atuin"
    echo "  targets: pi kali"
}

parse_args() {
    if (($# == 0)); then
        usage >&2
        exit 1
    fi

    while (($# > 0)); do
        case "$1" in
            zshrc | zshenv | zshenvlocal | zprofile | ssh | nvim | yazi | fzf | zellij | atuin)
                SOURCES+=("$1")
                ;;
            pi | kali)
                TARGETS+=("$1")
                ;;
            -h | --help)
                usage
                exit
                ;;
            *)
                usage >&2
                exit 1
                ;;
        esac
        shift
    done
}

copy_files() {
    local source
    local target

    for source in "${SOURCES[@]}"; do
        for target in "${TARGETS[@]}"; do
            rsync --verbose --recursive --copy-links \
                "${SOURCES_MAPPING[$source]}" \
                "${target}:${SOURCES_MAPPING[$source]}"
        done
    done
}

main() {
    require_wsl
    parse_args "$@"
    copy_files
}

main "$@"
